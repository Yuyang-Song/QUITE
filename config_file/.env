# This is a configuration file for environment variables used in the project.

# API keys and model configurations, since there are multiple models used in the project,
# we define them here for easy access and modification.
# Note: Replace [your_api_key_here] and [your_model_url_here] with actual values.
############ Example ############ 
# REASONING_MODEL_API_KEY=sk-123456
# REASONING_MODEL=deepseek-r1 (we set the default model in all agent configurations as shown below)
# REASONING_MODEL_URL=https://api.deepseek.com/v1
############ Example ############ 

REASONING_MODEL_API_KEY=[your_api_key_here]
REASONING_MODEL=deepseek-r1
REASONING_MODEL_URL=[your_model_url_here]

DECISION_MODEL_API_KEY=[your_api_key_here]
DECISION_MODEL=claude-3-7-sonnet-20250219
DECISION_MODEL_URL=[your_model_url_here]

ASSISTANT_MODEL_API_KEY=[your_api_key_here]
ASSISTANT_MODEL=claude-3-7-sonnet-20250219
ASSISTANT_MODEL_URL=[your_model_url_here]

# Database configuration
# These variables are used to connect to the PostgreSQL database.
# Ensure that the database is running and accessible at the specified host and port.
# Note: Replace the values with your actual database credentials.
############ Example ############ 
# DB_NAME=tpch_s10
# DB_USER=postgres
# DB_PASSWORD=knob
# DB_HOST=localhost
# DB_PORT=5432
# DB_PASSWORD=knob
############ Example ############ 

DB_NAME=[your_database_name]
DB_USER=[your_database_user]
DB_PASSWORD=[your_database_password]
DB_HOST=[localhost] 
DB_PORT=[5432] 

# Project root directory
############# Example ############
# PROJECT_ROOT=/root/syy/QUITE
############# Example ############

PROJECT_ROOT=[/your_project_root_path]